WITH product_revenue AS(
	SELECT
		product_name,
		SUM(quantity * unit_price) AS revenue_product
	FROM order_items oi
	JOIN products p
		ON p.product_id = oi.product_id
	GROUP BY product_name
),
segment_p AS(
	SELECT
		product_name,
		revenue_product,
		NTILE(3) OVER(
			ORDER BY revenue_product DESC
		) AS segment
	FROM product_revenue
)
SELECT
	product_name,
	revenue_product,
	segment,
	CASE
		WHEN segment = 1 THEN 'Top'
		WHEN segment = 2 THEN 'Medium'
		WHEN segment = 3 THEN 'Low'
	END AS product_level
FROM segment_p;

WITH customer_spent AS(
		SELECT
			c.customer_id,
			SUM(quantity * unit_price) total_spent
		FROM customers c
		JOIN orders o
			ON c.customer_id = o.customer_id
