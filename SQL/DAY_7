WITH categories_nums AS(
	SELECT
		category_name,
		p.product_id,
		p.category_id,
		unit_price
	FROM order_items oi
	JOIN products p
		ON p.product_id = oi.product_id
	JOIN categories c
		ON c.category_id = p.category_id
)
SELECT
	category_name,
	product_id,
	category_id,
	unit_price,
	RANK() OVER(
		PARTITION BY category_name
		ORDER BY unit_price DESC
	) AS category_product_rank
FROM categories_nums;

WITH ranked_products AS(
	SELECT
		category_name,
		p.product_id,
		p.category_id,
		unit_price,
		ROW_NUMBER() OVER(
			PARTITION BY category_name
			ORDER BY unit_price DESC
		) AS category_product_rank
	FROM order_items oi
	JOIN products p
		ON p.product_id = oi.product_id
	JOIN categories c
		ON c.category_id = p.category_id
)
SELECT *
FROM ranked_products
WHERE category_product_rank = 1;

