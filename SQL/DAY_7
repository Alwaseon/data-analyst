WITH categories_nums AS(
	SELECT
		c.category_name,
		p.product_id,
		p.category_id,
		SUM(quantity * unit_price) unit_price
	FROM order_items oi
	JOIN products p
		ON p.product_id = oi.product_id
	JOIN categories c
		ON c.category_id = p.category_id
	GROUP BY c.category_name, p.product_id, p.category_id
),
ranked_categories AS(
	SELECT
		category_name,
		product_id,
		category_id,
		unit_price,
		RANK() OVER(
			PARTITION BY category_name
			ORDER BY unit_price DESC
		) category_product_rank
	FROM categories_nums
)
SELECT *
FROM ranked_categories;

WITH product_sales AS(
	SELECT
		p.product_id,
		product_name,
		SUM(quantity) product_sales
	FROM order_items oi
	JOIN products p
		ON p.product_id = oi.product_id
	GROUP BY p.product_id, product_name
)
SELECT 
	product_id,
	product_name,
	product_sales,
	RANK() OVER(
		ORDER BY product_sales DESC
	) AS product_sales_rank
FROM product_sales;

WITH categories_revenue AS(
	SELECT
		c.category_name,
		SUM(quantity * unit_price) category_revenue
	FROM order_items oi
	JOIN products p
		ON p.product_id = oi.product_id
	JOIN categories c
		ON c.category_id = p.category_id
	GROUP BY c.category_name
),
avg_categories_revenue AS(
	SELECT AVG(category_revenue) avg_revenue
	FROM categories_revenue
)
SELECT *
FROM categories_revenue, avg_categories_revenue
WHERE category_revenue > avg_revenue;



WITH customer_most_exp_order AS(
	SELECT
		c.customer_id,
		o.order_id,
		SUM(quantity * unit_price) order_cost
	FROM customers c
	JOIN orders o
		ON c.customer_id = o.customer_id
	JOIN order_items oi
		ON o.order_id = oi.order_id
	GROUP BY c.customer_id, o.order_id
),
order_ranking AS (
	SELECT
		customer_id,
		order_id,
		order_cost,
		RANK() OVER(
			PARTITION BY customer_id
			ORDER BY order_cost DESC
		) ranking_orders_cost
	FROM customer_most_exp_order
)
SELECT *
FROM order_ranking
WHERE ranking_orders_cost = 1;