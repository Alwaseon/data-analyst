WITH customer_orders AS (
    SELECT
        c.customer_id,
        first_name,
        last_name,
        o.order_id,
        SUM(quantity * unit_price) AS revenue
    FROM customers c
    JOIN orders o
        ON c.customer_id = o.customer_id
    JOIN order_items oi
        ON oi.order_id = o.order_id
    GROUP BY
        c.customer_id,
        first_name,
        last_name,
        o.order_id
),max_and_min AS(
		SELECT
			first_name,
			last_name,
			customer_id,
			revenue,
			MAX(revenue) OVER(PARTITION BY customer_id ORDER BY customer_id) AS max_val,
			MIN(revenue) OVER(PARTITION BY customer_id ORDER BY customer_id) AS min_val
		FROM customer_orders
)
SELECT 
		first_name,
	    last_name,
		customer_id,
		revenue,
		max_val,
		min_val,
		max_val - min_val AS diff
FROM max_and_min;

WITH customer_orders AS (
    SELECT
        c.customer_id,
        first_name,
        last_name,
        o.order_id,
        SUM(quantity * unit_price) AS revenue
    FROM customers c
    JOIN orders o
        ON c.customer_id = o.customer_id
    JOIN order_items oi
        ON oi.order_id = o.order_id
    GROUP BY
        c.customer_id,
        first_name,
        last_name,
        o.order_id
)
SELECT
    customer_id,
    order_id,
    revenue,
    AVG(revenue) OVER(
        PARTITION BY customer_id
    ) AS avg_revenue,
    revenue -
    AVG(revenue) OVER(
        PARTITION BY customer_id
    ) AS offset_rev
FROM customer_orders;


