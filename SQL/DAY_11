WITH order_revenue AS(
	SELECT
		order_id,
		SUM(quantity * unit_price) revenue
	FROM order_items 
	GROUP BY order_id 
)
SELECT *
FROM order_revenue
ORDER BY revenue DESC;

WITH order_revenue AS(
	SELECT
		order_id,
		SUM(quantity * unit_price) revenue
	FROM order_items 
	GROUP BY order_id 
)
SELECT *
FROM order_revenue
WHERE revenue > (SELECT AVG(revenue) FROM order_revenue)
ORDER BY revenue DESC;

