	last_name,
	customer_id,
	total_spent,
	order_id,
	FIRST_VALUE(total_spent) OVER(PARTITION BY customer_id ORDER BY total_spent  DESC) AS max_ord_cost,
	total_spent - FIRST_VALUE(total_spent) OVER(ORDER BY total_spent  DESC) AS diff
FROM customer_spent;

WITH customer_spent AS(
	SELECT
		c.first_name,
		c.last_name,
		c.customer_id,
		o.order_id,
		SUM(quantity * unit_price) total_spent
	FROM customers c
	JOIN orders o
		ON c.customer_id = o.customer_id
	JOIN order_items oi
		ON oi.order_id = o.order_id
	GROUP BY 
		first_name,
		last_name,
		c.customer_id,
		o.order_id
), ranking AS(
		SELECT
			first_name,
			last_name,
			customer_id,
			total_spent, 
			order_id,
			NTILE(3) OVER(ORDER BY total_spent) AS rankn
		FROM customer_spent
)
SELECT *,
CASE
WHEN rankn = 3 THEN 'Top'
WHEN rankn = 2 THEN 'Medium'
WHEN rankn = 1 THEN 'Low'
End
FROM ranking;

WITH customer_spent AS(
    SELECT
        c.first_name,
        c.last_name,
        c.customer_id,
        SUM(quantity * unit_price) AS total_spent
    FROM customers c
    JOIN orders o
        ON c.customer_id = o.customer_id
    JOIN order_items oi
        ON oi.order_id = o.order_id
    GROUP BY
        c.first_name,
        c.last_name,
        c.customer_id
)
SELECT *
FROM (
    SELECT *,
           DENSE_RANK() OVER(ORDER BY total_spent DESC) AS rank_spent
    FROM customer_spent
) 
WHERE rank_spent = 1;

