WITH customer_spent AS(
    SELECT
        c.first_name,
        c.last_name,
        c.customer_id,
        SUM(quantity * unit_price) AS customer_spent
    FROM customers c
    JOIN orders o
        ON c.customer_id = o.customer_id
    JOIN order_items oi
        ON oi.order_id = o.order_id
    GROUP BY
        c.customer_id,
        c.first_name,
        c.last_name
)
SELECT
    first_name,
    last_name,
    customer_id,
    customer_spent,
    AVG(customer_spent) OVER() AS avg_customer,
    customer_spent -
    AVG(customer_spent) OVER() AS diff
FROM customer_spent;

WITH customer_spent AS(
    SELECT
        c.first_name,
        c.last_name,
        c.customer_id,
        SUM(quantity * unit_price) AS customer_spent
    FROM customers c
    JOIN orders o
        ON c.customer_id = o.customer_id
    JOIN order_items oi
        ON oi.order_id = o.order_id
    GROUP BY
        c.customer_id,
        c.first_name,
        c.last_name
), percent_ranks AS(
	SELECT 
		first_name,
		last_name,
		customer_id,
		customer_spent,
		PERCENT_RANK() OVER(ORDER BY customer_spent) AS percents 
	FROM customer_spent
)
SELECT *
FROM percent_ranks
WHERE percents > 0.90