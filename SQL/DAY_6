WITH top3_customers AS(
	SELECT
		c.customer_id,
		first_name,
		last_name,
		SUM(quantity * unit_price)total_spent
	FROM customers c
	JOIN orders o
		ON c.customer_id = o.customer_id
	JOIN order_items oi
		ON o.order_id = oi.order_id
	GROUP BY c.customer_id
)
SELECT *
FROM top3_customers
ORDER BY total_spent DESC
LIMIT 3;

WITH top3_products AS(
	SELECT
		product_name,
		SUM(quantity) total_sells
	FROM order_items o
	JOIN products p
		ON p.product_id = o.product_id
	GROUP BY product_name
)
SELECT *
FROM top3_products
ORDER BY total_sells DESC
LIMIT 3;


WITH top3_categories AS(
	SELECT 
		category_name,
		SUM(quantity * unit_price) category_revenue
	FROM order_items oi	
	JOIN products p
		ON oi.product_id = p.product_id
	JOIN categories cat
		ON p.category_id = cat.category_id
	GROUP BY category_name
)
SELECT * 
FROM top3_categories
ORDER BY category_revenue DESC
LIMIT 3;

WITH categories_revenue AS(
	SELECT 
		category_name,
		SUM(quantity * unit_price) category_revenue
	FROM order_items oi	
	JOIN products p
		ON oi.product_id = p.product_id
	JOIN categories cat
		ON p.category_id = cat.category_id
	GROUP BY category_name
), avg_categories_revenue AS (
	SELECT AVG(category_revenue) avg_revenue
	FROM categories_revenue
)
SELECT * 
FROM categories_revenue, avg_categories_revenue
WHERE avg_revenue < category_revenue
ORDER BY category_revenue DESC;

WITH customer_orders AS(
	SELECT
		c.customer_id,
		first_name,
		last_name,
		COUNT(order_id) orders_count
	FROM customers c
	JOIN orders o
		ON o.customer_id = c.customer_id
	GROUP BY c.customer_id,first_name,last_name
), avg_customer_orders_count AS(
	SELECT AVG(orders_count) avg_count
	FROM customer_orders
)
SELECT *
FROM customer_orders, avg_customer_orders_count
WHERE  orders_count > avg_count;