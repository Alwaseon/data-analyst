FROM all_customers;

WITH customer_orders AS(
	SELECT c.customer_id, order_id, order_date
	FROM customers c
	JOIN orders o
	ON c.customer_id = o.customer_id
)
SELECT *
FROM customer_orders;

WITH product_sales AS(
	SELECT SUM(quantity) total_quantity, p.product_name
	FROM order_items o
	JOIN products p
	ON p.product_id = o.product_id
	GROUP BY product_name
)
SELECT *
FROM product_sales;


WITH customer_totals AS(
    SELECT
        c.customer_id,
        first_name,
        last_name,
        SUM(quantity * unit_price) customer_spent
    FROM customers c
    JOIN orders o
        ON c.customer_id = o.customer_id
    JOIN order_items oi
        ON oi.order_id = o.order_id
    GROUP BY c.customer_id, first_name, last_name
)
SELECT *
FROM customer_totals
WHERE customer_spent >
(
    SELECT AVG(customer_spent)
    FROM customer_totals
);

WITH order_totals AS(
    SELECT
        o.order_id,
        o.customer_id,
        SUM(quantity * unit_price) order_total
    FROM orders o
    JOIN order_items oi
        ON o.order_id = oi.order_id
    GROUP BY o.order_id, o.customer_id
)
SELECT *
FROM order_totals
WHERE order_total =
(
    SELECT MAX(order_total)
    FROM order_totals
);

