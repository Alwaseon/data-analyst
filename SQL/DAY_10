WITH order_revenue AS (
    SELECT
        order_id,
        SUM(quantity * unit_price) AS revenue
    FROM order_items
    GROUP BY order_id
)
SELECT
    order_id,
    revenue,
    SUM(revenue) OVER(
        ORDER BY order_id
        ROWS BETWEEN
            1 PRECEDING
            AND
            1 FOLLOWING
    ) AS local_sum
FROM order_revenue;

WITH order_revenue AS (
    SELECT
        c.customer_id,
        o.order_id,
        SUM(quantity * unit_price) AS revenue
    FROM customers c
    JOIN orders o
        ON c.customer_id = o.customer_id
    JOIN order_items oi
        ON oi.order_id = o.order_id
    GROUP BY c.customer_id, o.order_id
)
SELECT
    customer_id,
    order_id,
    revenue,
    AVG(revenue) OVER(
        PARTITION BY customer_id
        ORDER BY order_id
        ROWS BETWEEN
            1 PRECEDING
            AND
            CURRENT ROW
    ) AS avg_last_two
FROM order_revenue;

WITH order_revenue AS (
    SELECT
        c.customer_id,
        o.order_id,
        SUM(quantity * unit_price) AS revenue
    FROM customers c
    JOIN orders o
        ON c.customer_id = o.customer_id
    JOIN order_items oi
        ON oi.order_id = o.order_id
    GROUP BY c.customer_id, o.order_id
), avg_ord AS(
	SELECT
		customer_id,
		order_id,
		revenue,
		AVG(revenue) OVER(
        PARTITION BY customer_id
        ORDER BY order_id
        ROWS BETWEEN
            UNBOUNDED PRECEDING
            AND
            1 PRECEDING
    ) AS avg_b
	FROM order_revenue
)
SELECT
    customer_id,
    order_id,
    revenue,
	revenue - avg_b AS diff
FROM avg_ord;

WITH order_revenue AS (
    SELECT
        c.customer_id,
        o.order_id,
        SUM(quantity * unit_price) AS revenue
    FROM customers c
    JOIN orders o
        ON c.customer_id = o.customer_id
    JOIN order_items oi
        ON oi.order_id = o.order_id
    GROUP BY
        c.customer_id,
        o.order_id
),
max_order AS (
    SELECT
        customer_id,
        order_id,
        revenue,
        FIRST_VALUE(revenue) OVER(
            PARTITION BY customer_id
            ORDER BY revenue DESC
        ) AS max_order_revenue
    FROM order_revenue
)
SELECT
    customer_id,
    order_id,
    revenue,
    max_order_revenue,
    revenue - max_order_revenue AS revenue_diff
FROM max_order
ORDER BY customer_id, order_id