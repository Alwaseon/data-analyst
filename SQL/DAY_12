EXPLAIN ANALYZE
SELECT
    c.customer_id,
    SUM(quantity*unit_price)
FROM customers c
JOIN orders o
    ON c.customer_id=o.customer_id
JOIN order_items oi
    ON oi.order_id=o.order_id
GROUP BY c.customer_id;

